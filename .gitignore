# ═══════════════════════════════════════════════════════════════════════
#  Thrivo .gitignore (v10)
# ═══════════════════════════════════════════════════════════════════════

# ── User data & secrets — NEVER commit to main branch ──
data_*.json
users.json
subscriptions.json
public_price_history.json    # local dev only — DB is canonical in prod
thrivo_shared_data.json      # legacy
ds_tracker_data.json         # legacy
*.bak
*.backup

# ── SQLite database (lives on thrivo-data-backup branch ONLY, never main) ──
thrivo.db
thrivo.db-journal
thrivo.db-wal
thrivo.db-shm
*.sqlite
*.sqlite3

# ── Streamlit secrets ──
.streamlit/secrets.toml
secrets.toml
.env
.env.*
!.env.example

# ── Python ──
__pycache__/
*.py[cod]
*$py.class
*.so
.Python
build/
dist/
*.egg-info/
.eggs/
*.egg

# ── Virtual envs ──
venv/
env/
.venv/
.env/

# ── Test / coverage ──
.coverage
.coverage.*
htmlcov/
.pytest_cache/
.mypy_cache/
.ruff_cache/

# ── IDEs ──
.vscode/
.idea/
*.swp
*.swo
*~

# ── OS ──
.DS_Store
.AppleDouble
._*
Thumbs.db
ehthumbs.db
Desktop.ini

# ── Deploy platforms ──
.streamlit/credentials.toml
.render/
.railway/
.vercel/

# ── Logs ──
*.log
logs/

# ── Icons stay tracked ──
!static/manifest.json
!static/sw.js
!static/icon-*.png
!static/favicon-*.png

# ── Scraper output IS tracked (so cache-fallback works) ──
!public_prices.json
